; CPU overhead test: Low-depth single job
; Measures per-request CPU cost with minimal queuing
; Used to compare QoS enabled vs disabled overhead
[global]
ioengine=libaio
direct=1
time_based=1
runtime={{ runtime }}
ramp_time={{ ramp_time }}
group_reporting=1

[cpu-overhead-test]
filename={{ device }}
rw=randread
bs=4k
iodepth=1
numjobs=1
; Use default priority (BE class)
prio=4
prioclass=2
