; Buffered workload: Concurrent high-priority reads + normal-priority writes
; Tests the page cache / writeback submission path (vs direct I/O in mixed_workload.fio.j2)
; psync + buffered I/O means writes go through the page cache and writeback coalesces
; them into larger batches, producing different doorbell and merge patterns than direct I/O.
;
; Uses psync (not mmap) because mmap engine cannot open raw block devices.
;
; Both job sections run concurrently within a single fio process,
; ensuring synchronized start/end times for accurate comparison.
[global]
ioengine=psync
direct=0
time_based=1
runtime={{ runtime }}
ramp_time={{ ramp_time }}
; Per-job stats for priority class comparison
group_reporting=0
{% if cpus_allowed %}
cpus_allowed={{ cpus_allowed }}
{% endif %}

[high-prio-reads]
filename={{ device }}
rw={{ high_rw | default('randread') }}
bs={{ high_bs | default('4k') }}
; psync is synchronous (iodepth=1), concurrency comes from numjobs
numjobs={{ high_numjobs }}
; IOPRIO_CLASS_RT (class 1), highest priority within class
prio={{ high_prio | default(0) }}
prioclass={{ high_prioclass | default(1) }}
new_group

[normal-prio-writes]
filename={{ device }}
rw={{ normal_rw | default('write') }}
bs={{ normal_bs | default('1m') }}
; psync is synchronous (iodepth=1), concurrency comes from numjobs
numjobs={{ normal_numjobs }}
{% if normal_rw | default('write') in ['write', 'randwrite'] %}
; Offset writes to second half of device to avoid overlap
offset=50%
size=50%
{% endif %}
; IOPRIO_CLASS_BE (class 2), middle priority
prio={{ normal_prio | default(4) }}
prioclass={{ normal_prioclass | default(2) }}
