; Mixed workload: Concurrent high-priority reads + normal-priority writes
; Primary QoS validation workload - creates contention for scheduler testing
; 20% high-priority (RT class) + 80% normal-priority (BE class)
;
; Both job sections run concurrently within a single fio process,
; ensuring synchronized start/end times for accurate comparison.
;
; Minimum effective depth: high_numjobs * high_iodepth + normal_numjobs * normal_iodepth >= 32
; With defaults (1*16 + 4*16 = 80), this creates sufficient contention.
[global]
ioengine=libaio
direct=1
time_based=1
runtime={{ runtime }}
ramp_time={{ ramp_time }}
; Per-job stats for priority class comparison
group_reporting=0

[high-prio-reads]
filename={{ device }}
rw=randread
bs=4k
iodepth={{ high_iodepth }}
numjobs={{ high_numjobs }}
; IOPRIO_CLASS_RT (class 1), highest priority within class
prio=0
prioclass=1
new_group

[normal-prio-writes]
filename={{ device }}
rw=write
bs=1m
iodepth={{ normal_iodepth }}
numjobs={{ normal_numjobs }}
; Offset writes to second half of device to avoid overlap
offset=50%
size=50%
; IOPRIO_CLASS_BE (class 2), middle priority
prio=4
prioclass=2
